flowchart TD
        U([Student / użytkownik]) --> W([ADK Web Client])
        W --> O[HackathonGenius<br/>SequentialAgent / orkiestrator]

        subgraph ORCH[Pipeline agentów]
            direction LR
            A1[IdeaAgent]
            A2[TechStackAgent]
            A3[TimelineAgent]
            A4[PitchAgent]
        end

        O --> A1 --> A2 --> A3 --> A4

        subgraph TOOLS[Narzędzia]
            direction LR
            T1[browse_hackathon_themes]
            T2[get_tech_stack_library]
            T3[get_sprint_templates]
            T4[get_pitch_frameworks]
        end

        A1 --> T1
        A2 --> T2
        A3 --> T3
        A4 --> T4

        S[(session.state)]
        A1 -. zapisuje .-> S
        A2 -. czyta i zapisuje .-> S
        A3 -. czyta i zapisuje .-> S
        A4 -. czyta i zapisuje .-> S

        M[model_config.py]
        A1 --> M
        A2 --> M
        A3 --> M
        A4 --> M

        P[LM Proxy for VS Code<br/>localhost:4000/openai/v1]
        V[VS Code Language Model API]
        L([Wybrany model LLM])
        M --> P --> V --> L

        classDef agent fill:#e0f2fe,stroke:#0284c7,stroke-width:2px,color:#0f172a;
        classDef tool fill:#ecfccb,stroke:#65a30d,stroke-width:1.5px,color:#1a2e05;
        classDef infra fill:#fef3c7,stroke:#d97706,stroke-width:1.5px,color:#3f2a00;
        classDef state fill:#fee2e2,stroke:#dc2626,stroke-width:1.5px,color:#3f0a0a;
        classDef user fill:#ede9fe,stroke:#7c3aed,stroke-width:1.5px,color:#2e1065;

        class O,A1,A2,A3,A4 agent;
        class T1,T2,T3,T4 tool;
        class M,P,V,L infra;
        class S state;
        class U,W user;